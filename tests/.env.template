# Integration test configuration.
#
# Copy this file to `.env` (same directory) and fill in the required values.
# The `.env` file is git-ignored — secrets never get committed.
#
# Keys without defaults here fall back to hardcoded defaults in src/config.ts.
#
# Convention: wrap every value in double quotes. This avoids `#` being parsed
# as a comment, preserves spaces, and keeps the file consistent.

# --- Agent server (required for integration tests) -----------------------

# AG-UI agent endpoint. Defaults to local dev server if unset.
SERVER_URL="http://localhost:7711/api/ai-agents/agent"

# JWT for the Smartcat user. REQUIRED — tests skip without it.
TOKEN=""

# --- Smartcat Drive (required for file uploads) --------------------------

DRIVE_URL="http://file-management-service-web.stage-feature-4.k8s.ya.sc.local"
DRIVE_APP_ID="aiAgents"
# REQUIRED for uploading test files to Drive.
DRIVE_SECRET_KEY=""

# --- AI user (required only for AI-based scenarios) ----------------------

# OpenAI-compatible /chat/completions endpoint.
AI_USER_URL="https://api.openai.com/v1/chat/completions"
# Model identifier.
AI_USER_MODEL="gpt-5.4"
# API key for the chosen endpoint. REQUIRED for AI scenarios.
AI_USER_API_KEY=""
